# Vercel API auth for local development
GITHUB_TOKEN=your_github_token_here

# Vercel preview deployment values used by the preview GitHub Actions workflow
VERCEL_PREVIEW_TOKEN=your_vercel_preview_token_here
VERCEL_PREVIEW_ORG_ID=your_vercel_preview_org_id_here
VERCEL_PREVIEW_PROJECT_ID=your_vercel_preview_project_id_here

# Vercel production deployment values used by the production GitHub Actions workflow
VERCEL_PRODUCTION_TOKEN=your_vercel_production_token_here
VERCEL_PRODUCTION_ORG_ID=your_vercel_production_org_id_here
VERCEL_PRODUCTION_PROJECT_ID=your_vercel_production_project_id_here

# Optional frontend variables
VITE_GITHUB_USERNAME=your-github-username
VITE_CODEPEN_USERNAME=your-codepen-username