{
  "name": "portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3000",
    "dev:vercel": "vercel dev",
    "build": "payload migrate && next build",
    "start": "next start",
    "lint": "prettier --check . && eslint \"src/**/*.{js,jsx,ts,tsx}\" --max-warnings=5",
    "lint:fix": "prettier --write . && eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix",
    "prettier": "prettier . --write",
    "preinstall": "node ./scripts/check-yarn.js",
    "prepare": "husky install",
    "prepack": "pinst --disable",
    "postpack": "pinst --enable"
  },
