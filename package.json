{
  "name": "portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:vercel": "node ./scripts/dev-vercel.mjs",
    "build": "tsc -b && vite build",
    "lint": "prettier --check . && eslint \"src/**/*.{js,jsx,ts,tsx}\" --max-warnings=0",
    "lint:fix": "prettier --write . && eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix",
    "preview": "vite preview",
    "prettier": "prettier . --write",
    "preinstall": "node ./scripts/check-yarn.js",
    "prepare": "husky install",
    "prepack": "pinst --disable",
    "postpack": "pinst --enable"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/lab": "^7.0.1-beta.23",
    "@mui/material": "^9.0.0",
    "@popperjs/core": "^2.11.8",
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.2",
    "@vercel/analytics": "2.0.1",
    "@vercel/blob": "^2.3.3",
    "bootstrap": "^5.3.3",
    "clsx": "^2.1.1",
    "commitlint": "^20.5.0",
    "i18next": "26.0.2",
    "i18next-http-backend": "^3.0.2",
    "lodash": "^4.18.1",
    "postcss": "^8.5.9",
    "prettier-plugin-organize-imports": "^4.1.0",
    "react": "^19.2.5",
    "react-bootstrap": "2.10.10",
    "react-dom": "^19.2.4",
    "react-i18next": "17.0.2",
    "react-icons": "^5.4.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.0.0",
    "@types/lodash": "^4.17.15",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "eslint": "^9.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.4.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.0",
    "prettier-plugin-css-order": "^2.2.0",
    "prettier-plugin-multiline-arrays": "^4.1.5",
    "prettier-plugin-organize-attributes": "^1.0.0",
    "prettier-plugin-style-order": "^0.2.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "~5.7.2",
    "vercel": "51.4.0",
    "vite": "^8.0.8"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "engines": {
    "node": ">=20.0.0",
    "yarn": ">=3.0.0"
  },
  "packageManager": "yarn@4.13.0"
}
