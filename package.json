    "@mui/material": "^9.0.1",
    "@payloadcms/db-sqlite": "^3.85.0",
    "@payloadcms/next": "^3.85.0",
    "@payloadcms/richtext-lexical": "^3.85.0",
    "@popperjs/core": "^2.11.8",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@vercel/analytics": "2.0.1",
    "bootstrap": "^5.3.8",
    "clsx": "^2.1.1",
    "commitlint": "^21.0.1",
