    "react-dom": "19.2.6",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0"
